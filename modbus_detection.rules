# ============================================================
# ELITEWOLF-Style OT Threat Detection Rules — Modbus TCP
# Port: 502 | Reference: CISA ELITEWOLF, NSA Cybersecurity
# ============================================================
# Compatible with: Snort 2.9+, Suricata 6+
# Usage: Include in snort.conf or suricata.yaml rules path
# ============================================================

# ── READ OPERATIONS (Low priority — recon detection) ────────

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Read Coil Status - Possible Reconnaissance";
  flow:to_server,established;
  content:"|00 00 00 00|"; depth:4;
  content:"|01|"; offset:7; depth:1;
  threshold:type threshold,track by_src,count 20,seconds 60;
  classtype:protocol-command-decode;
  priority:3;
  metadata:protocol modbus, tactic Discovery, technique T0888;
  sid:9000001; rev:2;
)

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Read Holding Registers - Rapid Polling Detected";
  flow:to_server,established;
  content:"|03|"; offset:7; depth:1;
  threshold:type threshold,track by_src,count 100,seconds 60;
  classtype:protocol-command-decode;
  priority:2;
  metadata:protocol modbus, tactic Discovery, technique T0840;
  sid:9000002; rev:2;
)

# ── WRITE OPERATIONS (High priority — unauthorized command) ──

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Write Single Coil - Unauthorized Command";
  flow:to_server,established;
  content:"|00 00 00 00|"; depth:4;
  content:"|05|"; offset:7; depth:1;
  classtype:protocol-command-decode;
  priority:2;
  metadata:protocol modbus, tactic Impact, technique T0855;
  sid:9000003; rev:2;
)

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Write Single Register - Possible Parameter Modification";
  flow:to_server,established;
  content:"|06|"; offset:7; depth:1;
  classtype:protocol-command-decode;
  priority:2;
  metadata:protocol modbus, tactic Impact, technique T0836;
  sid:9000004; rev:2;
)

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Write Multiple Coils - INCONTROLLER/PIPEDREAM Pattern";
  flow:to_server,established;
  content:"|00 00 00 00|"; depth:4;
  content:"|0F|"; offset:7; depth:1;
  classtype:protocol-command-decode;
  priority:1;
  metadata:protocol modbus, tactic Impact, technique T0855, malware INCONTROLLER;
  sid:9000005; rev:2;
)

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Write Multiple Registers - Bulk Parameter Change";
  flow:to_server,established;
  content:"|10|"; offset:7; depth:1;
  classtype:protocol-command-decode;
  priority:1;
  metadata:protocol modbus, tactic Impact, technique T0836;
  sid:9000006; rev:2;
)

# ── DIAGNOSTIC / DANGEROUS FUNCTION CODES ───────────────────

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Force Listen Only Mode - Denial of Control";
  flow:to_server,established;
  content:"|08 00 04|"; offset:7; depth:3;
  classtype:denial-of-service;
  priority:1;
  metadata:protocol modbus, tactic Impact, technique T0813;
  sid:9000007; rev:2;
)

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Restart Communications Option";
  flow:to_server,established;
  content:"|08 00 01|"; offset:7; depth:3;
  classtype:denial-of-service;
  priority:1;
  metadata:protocol modbus, tactic Impact, technique T0816;
  sid:9000008; rev:2;
)

alert tcp any any -> $OT_NET 502 (
  msg:"OT-MODBUS Return Query Data - Possible Fuzzing Activity";
  flow:to_server,established;
  content:"|08 00 00|"; offset:7; depth:3;
  threshold:type threshold,track by_src,count 5,seconds 30;
  classtype:attempted-dos;
  priority:2;
  metadata:protocol modbus, tactic Evasion;
  sid:9000009; rev:1;
)

# ── UNAUTHORIZED SOURCE DETECTION ───────────────────────────

alert tcp !$ENG_STATIONS any -> $OT_NET 502 (
  msg:"OT-MODBUS Connection from Non-Engineering Source";
  flow:to_server,established;
  classtype:policy-violation;
  priority:2;
  metadata:protocol modbus, tactic InitialAccess, technique T0886;
  sid:9000010; rev:2;
)

alert tcp $ENTERPRISE_NET any -> $OT_NET 502 (
  msg:"OT-MODBUS IT-to-OT Direct Connection - Policy Violation";
  flow:to_server,established;
  classtype:policy-violation;
  priority:1;
  metadata:protocol modbus, tactic LateralMovement, technique T0866;
  sid:9000011; rev:2;
)

# ── EXCEPTION / ERROR RESPONSE MONITORING ───────────────────

alert tcp $OT_NET 502 -> any any (
  msg:"OT-MODBUS Exception Response - Possible Attack Causing Errors";
  flow:from_server,established;
  content:"|81|"; offset:7; depth:1;
  threshold:type threshold,track by_dst,count 10,seconds 60;
  classtype:protocol-command-decode;
  priority:3;
  metadata:protocol modbus;
  sid:9000012; rev:1;
)
